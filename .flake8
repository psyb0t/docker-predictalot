[flake8]
# Match [tool.black] line-length = 100.
max-line-length = 100

# E203: whitespace before ':' — disagrees with black's slice formatting.
# W503: line break before binary operator — also black-style.
extend-ignore = E203, W503

exclude =
    .git,
    .venv,
    venv,
    __pycache__,
    .pytest_cache,
    .mypy_cache,
    .ruff_cache,
    build,
    dist,
    *.egg-info,
    .research_files,
    tests/integration/.fixtures
